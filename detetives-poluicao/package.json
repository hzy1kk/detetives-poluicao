{
  "name": "detetives-poluicao",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run qr && npm run docs:sync && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docs:sync": "cp public/logo-escola.png docs/assets/logo-escola.png 2>/dev/null; rm -rf public/docs && cp -R docs public/docs",
    "docs:pdf": "npm run docs:sync && node scripts/generate-pdfs.mjs",
    "qr": "node scripts/generate-qr.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/qrcode": "^1.5.6",
    "framer-motion": "^12.40.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "puppeteer": "^24.43.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
